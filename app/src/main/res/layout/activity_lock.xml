<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- The only thing on screen: a big countdown that bounces around. -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:text="0:00:00"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.03"
        android:maxLines="1"
        android:includeFontPadding="false" />

    <!-- Completion / congrats screen (shown when the lock finishes). -->
    <LinearLayout
        android:id="@+id/completionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#000000"
        android:padding="36dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="72sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Time's up!"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvCompletionMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You stayed off your phone."
            android:textSize="16sp"
            android:fontFamily="@font/inter"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="DONE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/orange_primary" />

    </LinearLayout>

</FrameLayout>
