<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Big centered flip-clock countdown -->
    <LinearLayout
        android:id="@+id/clockWrap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp">

        <!-- HOURS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="6dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/bg_flip_card">

                <TextSwitcher
                    android:id="@+id/tsHours"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOURS"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.18"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <!-- MINUTES -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="6dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/bg_flip_card">

                <TextSwitcher
                    android:id="@+id/tsMinutes"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIN"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.18"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <!-- SECONDS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="6dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/bg_flip_card">

                <TextSwitcher
                    android:id="@+id/tsSeconds"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEC"
                android:textSize="11sp"
                android:textColor="@color/orange_primary"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.18"
                android:layout_marginTop="10dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Completion / congrats screen -->
    <LinearLayout
        android:id="@+id/completionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#000000"
        android:padding="36dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="72sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Time's up!"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvCompletionMsg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You stayed off your phone."
            android:textSize="16sp"
            android:fontFamily="@font/inter"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="48dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDone"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="DONE"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_gradient" />

    </LinearLayout>

</FrameLayout>
