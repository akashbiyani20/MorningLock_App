<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ════════════ CONTENT (swaps between sections) ════════════ -->
        <FrameLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ─────────── ALARM SECTION ─────────── -->
            <LinearLayout
                android:id="@+id/alarmSection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="48dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Alarms"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/text_primary"
                        android:includeFontPadding="false"/>

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_settings"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Settings"
                        android:padding="12dp"/>

                </LinearLayout>

                <!-- Permission warning — only visible when permissions are missing -->
                <TextView
                    android:id="@+id/tvPermWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#1A2200"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="12dp"
                    android:textColor="#AAFF44"
                    android:fontFamily="@font/inter"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <!-- Alarm list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerAlarms"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="88dp"
                    android:clipToPadding="false"/>

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/layoutEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏰"
                        android:textSize="48sp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="No alarms yet"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter_bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Tap + to add your first one"
                        android:textColor="@color/text_hint"
                        android:fontFamily="@font/inter"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─────────── TIMER / FOCUS SECTION ─────────── -->
            <LinearLayout
                android:id="@+id/timerSection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="48dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Focus"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/text_primary"
                        android:includeFontPadding="false"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock your phone and stay present"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

                <!-- Big duration readout -->
                <TextView
                    android:id="@+id/tvTimerDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="30 min"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_bold"
                    android:letterSpacing="-0.02"
                    android:textColor="@color/orange_primary"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="14dp"/>

                <!-- Preset chips (left) + fine grain slider (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/chip5"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="10dp"
                            android:gravity="center"
                            android:text="5 min"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_card_normal"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip10"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="10dp"
                            android:gravity="center"
                            android:text="10 min"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_card_normal"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip30"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="10dp"
                            android:gravity="center"
                            android:text="30 min"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_card_normal"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip60"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="10dp"
                            android:gravity="center"
                            android:text="1 hour"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_card_normal"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/chip180"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="3 hours"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_card_normal"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                    <com.morninglock.GrainRuler
                        android:id="@+id/grainSlider"
                        android:layout_width="96dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="16dp"
                        app:rulerVertical="true"/>

                </LinearLayout>

                <!-- Start button -->
                <Button
                    android:id="@+id/btnStartFocus"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="START FOCUS"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/inter_bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_btn_gradient"
                    android:textColor="#FFFFFF"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- ════════════ BOTTOM NAVIGATION (icons only) ════════════ -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="@color/bg_card"
            android:elevation="12dp">

            <ImageButton
                android:id="@+id/btnTabAlarm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_tab_alarm"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Alarms"
                android:scaleType="centerInside"
                android:padding="18dp"/>

            <ImageButton
                android:id="@+id/btnTabTimer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/ic_tab_timer"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Focus timer"
                android:scaleType="centerInside"
                android:padding="18dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- FAB (Add alarm) — sits above the bottom nav, alarm tab only -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddAlarm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="88dp"
        android:contentDescription="Add alarm"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/orange_primary"
        app:tint="@android:color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
