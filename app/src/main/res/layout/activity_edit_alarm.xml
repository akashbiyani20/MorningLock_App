<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Time wheels (hour / minute / AM-PM) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_card_normal"
            android:paddingVertical="10dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp">

            <NumberPicker
                android:id="@+id/npHour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/WheelPicker" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/text_primary"
                android:paddingHorizontal="4dp" />

            <NumberPicker
                android:id="@+id/npMinute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/WheelPicker" />

            <NumberPicker
                android:id="@+id/npAmPm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:theme="@style/WheelPicker" />

        </LinearLayout>

        <!-- "Alarm in Xh Ym" -->
        <TextView
            android:id="@+id/tvTimeUntil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/orange_primary"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:layout_marginBottom="28dp"
            android:visibility="gone" />

        <!-- Label section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LABEL"
            android:textSize="11sp"
            android:textColor="@color/orange_primary"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Wake up"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:fontFamily="@font/inter"
            android:background="@drawable/bg_card_normal"
            android:padding="14dp"
            android:inputType="text"
            android:layout_marginBottom="24dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1E1E1E" android:layout_marginBottom="20dp"/>

        <!-- Primary toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Primary Alarm 🔒"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stopping this alarm starts the morning lock"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/switch_thumb_tint"
                app:trackTint="@color/switch_track_tint"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvPrimaryNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Only one Primary alarm should be active at a time."
            android:textSize="12sp"
            android:fontFamily="@font/inter"
            android:textColor="@color/orange_muted"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Lock duration section -->
        <LinearLayout
            android:id="@+id/lockSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_primary"
            android:padding="18dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lock Duration"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLockDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30 min"
                    android:textSize="20sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/orange_primary"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Horizontal grain ruler — scroll to set the lock duration -->
            <com.morninglock.GrainRuler
                android:id="@+id/rulerLock"
                android:layout_width="match_parent"
                android:layout_height="96dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scroll · 1 grain = 1 min · buzzes each step"
                android:textSize="11sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1E1E1E" android:layout_marginBottom="20dp"/>

        <!-- Vibrate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vibrate"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vibrate when alarm rings"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_hint" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchVibrate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/switch_thumb_tint"
                app:trackTint="@color/switch_track_tint"/>

        </LinearLayout>

        <!-- Ringtone -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RINGTONE"
            android:textSize="11sp"
            android:textColor="@color/orange_primary"
            android:textStyle="bold"
            android:fontFamily="@font/inter"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_normal"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:id="@+id/ringtoneRow">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ringtone"
                android:textSize="14sp"
                android:fontFamily="@font/inter"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvRingtone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Default alarm"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/inter"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Save button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SAVE ALARM"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.08"
            android:background="@drawable/bg_btn_gradient"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
