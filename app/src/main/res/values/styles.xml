<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MorningLock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">#CC5520</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Theme.MorningLock.WithBar" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">#CC5520</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="colorControlNormal">@color/text_primary</item>
        <item name="actionBarStyle">@style/DarkActionBarStyle</item>
    </style>

    <style name="DarkActionBarStyle" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/bg_dark</item>
        <item name="titleTextStyle">@style/ActionBarTitleStyle</item>
    </style>

    <style name="ActionBarTitleStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">@font/inter</item>
    </style>

    <!-- Theme overlay applied to the alarm-time NumberPickers (iOS-style wheels) -->
    <style name="WheelPicker">
        <item name="colorControlNormal">@color/orange_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

</resources>
